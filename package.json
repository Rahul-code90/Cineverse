{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter @workspace/api-server run dev",
    "dev:api": "pnpm --filter @workspace/api-server run dev",
    "dev:frontend": "pnpm --filter @workspace/cineverse-bookings run dev",
    "dev:ml": "cd artifacts/ml-service && python app.py",
    "dev:all": "concurrently \"pnpm run dev:api\" \"pnpm run dev:frontend\" \"pnpm run dev:ml\"",
    "build": "pnpm -r --if-present run build",
    "build:prod": "pnpm -r --filter !@workspace/mockup-sandbox --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
